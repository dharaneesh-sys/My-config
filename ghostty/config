# Font Configuration
font-size = 12
font-family = "JetBrainsMono Nerd Font"

# Window Configuration
window-decoration = false
window-padding-x = 6
window-padding-y = 6
background-opacity = 0.30
resize-overlay = never
clipboard-read = allow
clipboard-write = allow

# Cursor Configuration
cursor-style = block
cursor-style-blink = true

# Scrollback
scrollback-limit = 3500

# ANSI palette overrides:
# Ghostty maps some M3 color slots to the same value, which breaks
# distinguishable prompt colors (e.g. p10k). Override with distinct hues.
palette = 3=#f9e2af
palette = 4=#89b4fa
palette = 10=#a6e3a1

# Terminal features
mouse-hide-while-typing = true
copy-on-select = false
confirm-close-surface = false
app-notifications = no-clipboard-copy,no-config-reload

# Key bindings
keybind = ctrl+c=copy_to_clipboard
keybind = ctrl+v=paste_from_clipboard
keybind = ctrl+shift+n=new_window
keybind = ctrl+t=new_tab
keybind = ctrl+plus=increase_font_size:1
keybind = ctrl+minus=decrease_font_size:1
keybind = ctrl+zero=reset_font_size
keybind = shift+enter=text:\\n

# Split styling
unfocused-split-opacity = 0.3
unfocused-split-fill = #44464f

# Shell integration
shell-integration = detect
shell-integration-features = cursor,title

# Theme (auto-generated by theme-switcher)
theme = "Matugen"

# Misc
gtk-single-instance = true
